# Copie para docker/.env e ajuste os valores (o .env real é git-ignored).

# Banco (MariaDB) — acessível apenas dentro da rede do projeto, sem porta no host.
DB_NAME=fertways
DB_USER=fertways
DB_PASSWORD=troque-esta-senha
DB_ROOT_PASSWORD=troque-esta-senha-root

# Portas do host (só localhost); o Apache/Nginx faz o proxy para elas.
API_HOST_PORT=4103
WEB_HOST_PORT=4104

# Autenticação (JWT). Gere um secret forte: `openssl rand -hex 32`.
JWT_SECRET=gere-um-hex-de-64-caracteres
# Access token em SEGUNDOS (o backend faz Number()). 900 = 15 min.
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL_DAYS=30
